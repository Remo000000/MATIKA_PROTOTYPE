DEBUG=1
# Локально можно оставить короткий ключ; при DEBUG=0 нужен длинный случайный SECRET_KEY (см. README).
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=127.0.0.1,localhost

# PostgreSQL (recommended for production, Render, Heroku)
# DATABASE_URL=postgres://USER:PASSWORD@127.0.0.1:5432/matika
# Render/Heroku: задайте переменную DATABASE_URL из панели (PostgreSQL add-on).

# Организация по умолчанию (slug) — при мультитенантности создайте записи в админке и назначайте пользователей.
DEFAULT_ORGANIZATION_SLUG=default
DEFAULT_ORGANIZATION_NAME=Default organization

LANGUAGE_CODE=ru
TIME_ZONE=Asia/Almaty

CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000

# Почта: для сброса пароля и продакшена укажите SMTP (иначе письма в консоль).
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=1
# DEFAULT_FROM_EMAIL=noreply@example.com

# Опционально: push при обновлении расписания (Telegram бот + один email для алертов).
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# SCHEDULE_NOTIFY_EMAIL=
# Тесты: отключить рассылку — DISABLE_SCHEDULE_PUSH=1

# --- Production / HTTPS (при DEBUG=0 по умолчанию включены редирект на HTTPS и HSTS)
# SECURE_SSL_REDIRECT=1
# SECURE_HSTS_SECONDS=2592000
