@startuml MATIKA_Activity_ThreeRoles
!theme plain
title Қызмет диаграммасы — МАТИКА (3 рөл: студент | оқытушы | әкімші)

skinparam activityDiamond {
  BackgroundColor #FFF3CD
  BorderColor #856404
}

start

fork
  partition "Студент беті" {
    :**Бастау**;
    :Авторизация;
    :Басқару тақтасына кіру;
    :«Менің кестем» беті;
    repeat
      :Ауқымды таңдау\n(топ, сүзгілер, іздеу);
      if (ауқым дұрыс па?) then (иә)
        break
      else (жоқ)
        :Қате хабарлама;
      endif
    repeat while (қайта таңдау?) is (иә)
    ->жоқ;
    :Кесте торын қарау;
    if (экспорт керек пе?) then (иә)
      :Excel / ICS экспорты;
    else (жоқ)
    endif
    :Хабарламалар;
    :Профиль (қалау бойынша);
    :**Процесс аяқталды**;
  }

fork again
  partition "Оқытушы беті" {
    :**Басы**;
    :Авторизация;
    :Басқару тақтасына кіру;
    :Өз кестесін /\n«Менің топтарым» қарау;
    if (тілектерді өзгерту керек пе?) then (иә)
      :Кесте тілектерін енгізу\n(қалаулы күндер / сағаттар);
      :Мақұлдауға жіберу;
      note right
        Әкімші мақұлдағаннан кейін
        тілектер күшіне енеді
      end note
    else (жоқ)
    endif
    :Хабарламалар;
    :Оқытушы профилі;
    :**Аяқталды**;
  }

fork again
  partition "Әкімші беті" {
    :**Бастау**;
    :Авторизация;
    :Университет деректерін\nқарау / өңдеу;
    :Оқу жүктемелерін\nенгізу / тексеру;
    :Кестені құрастыру /\nоңтайландыру (ГА);
    :Талдау / алгоритм журналы\n(қалау бойынша);
    :Оқытушы тілек сұрауларын\nмақұлдау (қажет болса);
    :Хабарламалар;
    :**Аяқтау**;
  }

end fork

stop

@enduml
